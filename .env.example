# App
APP_HOST=localhost:3000
FRONTEND_URL=http://localhost:3000
SECRET_KEY_BASE=generate-with-rails-secret

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ascend_api_development

# Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
CUSTOM_OIDC_ISSUER=
CUSTOM_OIDC_CLIENT_ID=
CUSTOM_OIDC_CLIENT_SECRET=
CUSTOM_OIDC_NAME=Custom

# Admin (comma-separated email addresses)
ADMIN_EMAILS=

# AI (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Storage
STORAGE_SERVICE=local
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_BUCKET=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# Browserless (PDF/Screenshot)
PRINTER_ENDPOINT=http://localhost:3000
BROWSERLESS_TOKEN=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@ascend.app

# Embeddings (RAG) - requires OpenAI API key
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=768

# Google Sheets (RAG)
GOOGLE_SHEETS_API_KEY=

# Feature Flags
FLAG_DISABLE_SIGNUPS=false
FLAG_DISABLE_EMAIL_AUTH=false
FLAG_DISABLE_UPDATE_CHECK=false
FLAG_DISABLE_IMAGE_PROCESSING=false

# Rate Limits
CHAT_DAILY_LIMIT=50

# Rails
RAILS_MASTER_KEY=
RAILS_LOG_LEVEL=info
